@startuml DM
title Domain Model - AISafe (Phase 0 - WP1, WP2, WP3)

skinparam classAttributeIconSize 0
hide circle
hide methods

left to right direction

' --- SHARED VALUE OBJECTS ---
' Como o Operational Status é usado em 2 sítios (Aircraft e Airport), declaramos aqui em cima
class OperationalStatus <<Value Object>> {
    - status
}

' --- AGGREGATE: AIRCRAFT MODEL ---
package "Aircraft Model Aggregate" <<Rectangle>> {
    class AircraftModel <<Aggregate Root>> <<Entity>> {
        - manufacturer
        - modelName
        - fuelCapacity
        - maxRange
        - cruisingSpeed
    }

    class SeatConfiguration <<Value Object>> {
        - configurationName
        - capacity
    }

    AircraftModel "1" *-- "1..*" SeatConfiguration : has >
}

' --- AGGREGATE: AIRCRAFT ---
package "Aircraft Aggregate" <<Rectangle>> {
    class Aircraft <<Aggregate Root>> <<Entity>> {
        - registrationNumber
        - manufacturingDate
    }

    Aircraft "1" *-- "1" OperationalStatus : has >
}

' --- AGGREGATE: AIRPORT ---
package "Airport Aggregate" <<Rectangle>> {
    class Airport <<Aggregate Root>> <<Entity>> {
        - name
        - timezone
    }

    class IATACode <<Value Object>> {
        - code
    }

    class Location <<Value Object>> {
        - city
        - country
        - coordinates
    }

    class Runway <<Entity>> {
        - name
        - length
        - orientation
    }

    class AirplaneCertification <<Value Object>> {
        - certificationDate
    }

    Airport "1" *-- "1" IATACode : identified by >
    Airport "1" *-- "1" Location : located at >
    Airport "1" *-- "1..*" Runway : has >
    Airport "1" *-- "0..*" AirplaneCertification : grants >
    Airport "1" *-- "1" OperationalStatus : has >
}

' --- AGGREGATE: FLIGHT ROUTE ---
package "Flight Route Aggregate" <<Rectangle>> {
    class FlightRoute <<Aggregate Root>> <<Entity>> {
        - routeId
        - estimatedFlightTime
        - routeStatus
    }

    class RouteRequirement <<Value Object>> {
        - minRangeRequired
        - minCapacityRequired
    }

    class RouteHistory <<Value Object>> {
        - changeDate
        - description
    }

    FlightRoute "1" *-- "1" RouteRequirement : defined by >
    FlightRoute "1" *-- "0..*" RouteHistory : tracked by >
}

' --- AGGREGATE: SCHEDULED FLIGHT ---
package "Scheduled Flight Aggregate" <<Rectangle>> {
    class ScheduledFlight <<Aggregate Root>> <<Entity>> {
        - flightNumber
        - scheduledDateTime
        - status
    }
}

' --- EXTERNAL RELATIONS (BETWEEN AGGREGATES) ---
Aircraft "0..*" --> "1" AircraftModel : is instance of >
Aircraft "0..*" --> "1" SeatConfiguration : configured with >
AirplaneCertification "0..*" --> "1" AircraftModel : authorizes >

ScheduledFlight "0..*" --> "1" FlightRoute : follows >
ScheduledFlight "0..*" --> "1" Aircraft : assigned to >

FlightRoute "0..*" --> "1" Airport : origin >
FlightRoute "0..*" --> "1" Airport : destination >

@enduml